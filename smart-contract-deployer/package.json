{
  "name": "smart-contract-deployer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy:subscription:ethereum": "hardhat run scripts/deploy-subscription-system.cjs --config hardhat.simple.config.cjs --network ethereum",
    "deploy:subscription:base": "hardhat run scripts/deploy-subscription-system.cjs --config hardhat.simple.config.cjs --network base",
    "deploy:subscription:arbitrum": "hardhat run scripts/deploy-subscription-system.cjs --config hardhat.simple.config.cjs --network arbitrum",
    "deploy:all-mainnets": "node deploy-all-mainnets.cjs",
    "setup:price-updater": "node setup-price-updater.cjs",
    "test:price-update": "node scripts/test-price-update.cjs",
    "start:price-updater": "node scripts/price-updater.cjs",
    "start:price-updater-hybrid": "node scripts/price-updater-hybrid.cjs",
    "start:price-updater-arbitrum": "node scripts/price-updater-arbitrum-only.cjs",
    "deploy:cross-chain-readers": "node scripts/deploy-cross-chain-readers.cjs",
    "deploy:reader:base": "hardhat run scripts/deploy-cross-chain-readers-hardhat.cjs --config hardhat.simple.config.cjs --network base",
    "deploy:reader:ethereum": "hardhat run scripts/deploy-cross-chain-readers-hardhat.cjs --config hardhat.simple.config.cjs --network ethereum",
    "start:price-updater-smart": "node scripts/price-updater-smart.cjs",
    "start:price-updater-final": "node scripts/price-updater-final.cjs",
    "deploy:subscription-usdc": "node scripts/deploy-subscription-usdc-only.cjs deploy",
    "compile:subscription-usdc": "node scripts/deploy-subscription-usdc-only.cjs compile",
    "test:supabase": "node test-supabase.js",
    "create:subscription": "node create-test-subscription.js",
    "create:testdata": "node create-test-data.js",
    "add:deployment": "node add-missing-deployment.js",
    "check-env": "node check-env.cjs",
    "setup-deployment": "node scripts/setup-deployment.cjs",
    "deploy": "./deploy.sh",
    "deploy-all": "node scripts/deploy-all.cjs",
    "deploy:ethereum": "node scripts/deploy-ethereum.cjs",
    "deploy:polygon": "node scripts/deploy-polygon.cjs",
    "deploy:arbitrum": "node scripts/deploy-arbitrum.cjs",
    "deploy:optimism": "node scripts/deploy-optimism.cjs",
    "deploy:bnb": "node scripts/deploy-bnb.cjs",
    "deploy:avalanche": "node scripts/deploy-avalanche.cjs",
    "deploy:zksync": "node scripts/deploy-zksync.cjs",
    "deploy:scroll": "node scripts/deploy-scroll.cjs",
    "deploy:linea": "node scripts/deploy-linea.cjs",
    "deploy:hyperevm": "node scripts/deploy-hyperevm.cjs",
    "test:factories": "node scripts/test-factories.cjs",
    "docker:build": "docker build -t contractforge .",
    "docker:run": "docker run -p 80:80 contractforge"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@supabase/supabase-js": "^2.51.0",
    "@tanstack/react-query": "^5.62.11",
    "axios": "^1.10.0",
    "ethers": "^6.13.4",
    "i18next": "^24.2.0",
    "js-sha3": "^0.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^3.1.0",
    "viem": "^2.21.62",
    "wagmi": "^2.14.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@ledgerhq/hw-app-eth": "^6.45.10",
    "@ledgerhq/hw-transport-node-hid": "^6.29.8",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.13",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.14",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.0",
    "@nomicfoundation/ignition-core": "^0.15.13",
    "@openzeppelin/contracts": "^5.4.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/babel__generator": "^7.27.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "chai": "^4.5.0",
    "dotenv": "^17.2.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "hardhat": "^2.26.0",
    "hardhat-gas-reporter": "^2.3.0",
    "solc": "^0.8.20",
    "solidity-coverage": "^0.8.16",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  }
}
